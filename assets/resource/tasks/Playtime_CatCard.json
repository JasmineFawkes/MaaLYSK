							},
							"next": ["进入喵喵牌"]
						}
					}
				}
			]
		},
		"喵喵牌游玩男主": {
			"type": "checkbox",
			"default_case": ["沈星回", "黎深", "祁煜", "秦彻", "夏以昼"],
			"cases": [
				{
					"name": "沈星回",
					"pipeline_override": {
						"选择沈星回": {
							"enabled": true
						}
					}
				},
				{
					"name": "黎深",
					"pipeline_override": {
						"选择黎深": {
							"enabled": true
						}
					}
				},
				{
					"name": "祁煜",
					"pipeline_override": {
						"选择祁煜": {
							"enabled": true
						}
					}
				},
				{
					"name": "秦彻",
					"pipeline_override": {
						"选择秦彻": {
							"enabled": true
						}
					}
				},
				{
					"name": "夏以昼",
					"pipeline_override": {
						"选择夏以昼": {
							"enabled": true
						}
					}
